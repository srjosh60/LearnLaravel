{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.2"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:MVO5fwjnTCRApj4EKyIAkW1YcmI89cxXxTMCnVOtgrs=",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "@DB_HOST",
        "DB_PORT": "@DB_PORT",
        "DB_DATABASE": "@DB_DATABASE",
        "DB_USERNAME": "@DB_USERNAME",
        "DB_PASSWORD": "@DB_PASSWORD"
    }
}
